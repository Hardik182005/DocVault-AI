# BFAI Document Intelligence — Environment Variables
# Copy this file to .env and fill in your real keys

# ── AI — Groq (PRIMARY classifier + RAG agent) ──────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── AI — Gemini (FALLBACK #1 — used when Groq hits its token/rate limit) ──────
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI — OpenAI / ChatGPT (FALLBACK #2 + Whisper STT transcription) ───────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Voice — ElevenLabs TTS ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── CORS origins (comma-separated) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.web.app

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DIR=./storage

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
