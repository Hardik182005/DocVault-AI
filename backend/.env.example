# DocVault AI — Document Intelligence — Environment Variables
# Copy this file to .env and fill in your real keys (never commit .env)

# ── AI providers — auto-fallback chain: OpenAI → Groq → Gemini ───────────────
# OpenAI is tried first for complex work (classification + RAG). The others are
# used automatically if a provider errors or hits a rate/token limit.
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Voice — ElevenLabs TTS (default voice is female "Rachel") ────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── CORS origins (comma-separated) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.web.app

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DIR=./storage

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
